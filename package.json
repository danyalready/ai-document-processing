{
    "name": "ai-document-processing",
    "private": true,
    "packageManager": "pnpm@11.9.0",
    "scripts": {
        "dev": "turbo run dev",
        "build": "turbo run build",
        "dev:web": "pnpm --filter web dev",
        "dev:api": "pnpm --filter api start:dev",
        "dev:worker": "pnpm --filter worker dev"
    },
